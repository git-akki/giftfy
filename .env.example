# Demo mode — skip Firebase + Razorpay entirely, run the whole app on localStorage.
# Set to `true` to test without any backend setup. Leave commented for real mode.
# VITE_DEMO_MODE=true

# Firebase (required unless VITE_DEMO_MODE=true)
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Razorpay (required for paid tiers — use the TEST key for demo)
# Get from https://dashboard.razorpay.com/app/keys (Test Mode)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# MCP server (optional — only if using mcp-server/)
# Point to your deployed Cloud Functions API + a generated API key.
GIFTFY_API_URL=https://us-central1-your-project-id.cloudfunctions.net/api/v1
GIFTFY_API_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
